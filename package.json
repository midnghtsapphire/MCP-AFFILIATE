### `src/index.ts`
import express from 'express';
import bodyParser from 'body-parser';
import { connectDB } from './db/schema';
import { setupRoutes } from './api/routes';
import { setupMCTServer } from './mct/server';
const app = express();
const port = process.env.PORT || 3000;
app.use(bodyParser.json());
connectDB();
setupRoutes(app);
setupMCTServer();
app.listen(port, () => {
  console.log(`Server running on port ${port}`);
});
### `src/api/routes.ts`
import { Express } from 'express';
import { getAffiliates, createAffiliate, updateAffiliate, deleteAffiliate } from '../services/affiliateService';
export function setupRoutes(app: Express) {
  app.get('/affiliates', getAffiliates);
  app.post('/affiliates', createAffiliate);
  app.put('/affiliates/:id', updateAffiliate);
  app.delete('/affiliates/:id', deleteAffiliate);
}
### `src/db/schema.ts`
import mongoose from 'mongoose';
const AffiliateSchema = new mongoose.Schema({
  name: String,
  email: String,
  url: String,
  campaigns: [{ type: mongoose.Schema.Types.ObjectId, ref: 'Campaign' }]
});
export const Affiliate = mongoose.model('Affiliate', AffiliateSchema);
export function connectDB() {
  const uri = process.env.MONGODB_URI || 'mongodb://localhost/mct-affiliate';
  mongoose.connect(uri, { useNewUrlParser: true, useUnifiedTopology: true });
}
### `src/mct/server.ts`
