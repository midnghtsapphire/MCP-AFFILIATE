### `src/services/affiliateService.ts`
import { Affiliate } from '../db/schema';
export const getAffiliates = async (req, res) => {
  const affiliates = await Affiliate.find();
  res.json(affiliates);
};
export const createAffiliate = async (req, res) => {
  const newAffiliate = new Affiliate(req.body);
  await newAffiliate.save();
  res.status(201).send(newAffiliate);
};
export const updateAffiliate = async (req, res) => {
  const updatedAffiliate = await Affiliate.findByIdAndUpdate(req.params.id, req.body, { new: true });
  res.send(updatedAffiliate);
};
export const deleteAffiliate = async (req, res) => {
  await Affiliate.findByIdAndDelete(req.params.id);
  res.status(204).send();
};